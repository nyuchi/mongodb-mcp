{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mongodb-mcp-test",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MongoMcp"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MongoMcp",
        "name": "MCP_OBJECT"
      }
    ]
  }
}

{
  "name": "mongodb-mcp",
  "version": "0.1.20",
  "private": true,
  "description": "Authenticated remote MCP server for managing MongoDB, running on Cloudflare Workers with WorkOS AuthKit.",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",

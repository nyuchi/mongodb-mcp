    "@modelcontextprotocol/sdk": "^1.29.0",
    "@workos-inc/node": "^9.3.0",
    "agents": "^0.12.4",
    "hono": "^4.12.19",
    "jose": "^6.2.3",
    "mongodb": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@cloudflare/workers-types": "^4.20260518.1",
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  }

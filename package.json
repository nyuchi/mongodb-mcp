{
  "name": "mongodb-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Authenticated remote MCP server for managing MongoDB, running on Cloudflare Workers with WorkOS AuthKit.",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@workos-inc/node": "^8.10.0",
    "agents": "^0.9.0",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "mongodb": "^6.12.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240924.0",
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "2.1.9",
    "wrangler": "^3.85.0"
  }
}

# Copy to `fundi/.dev.vars` for `wrangler dev -c fundi/wrangler.jsonc`.
# Never commit the real file. In production set secrets with `wrangler secret put`.

# MongoDB connection string (the platform cluster Fundi writes tier-0 records to).
MONGODB_URI="mongodb+srv://user:pass@cluster.example.mongodb.net/?retryWrites=true&w=majority"

# --- WorkOS M2M gate (client_credentials) ---
# Non-secret; can also live in wrangler.jsonc vars.
WORKOS_AUTHKIT_DOMAIN="https://your-env.authkit.app"
WORKOS_M2M_CLIENT_ID="client_..."   # the Fundi M2M application id (JWT aud)
# Optional: restrict to specific WorkOS organizations (checked against org_id).
# WORKOS_ALLOWED_ORG_IDS="org_abc,org_def"

# what3words API key (write-time convenience layer). If absent, what3words is null.
WHAT3WORDS_API_KEY="..."

# Optional static bearer accepted on POST /tasks (server-to-server app surfaces).
# FUNDI_API_TOKEN="replace-with-`openssl rand -hex 32`"

# Dev-only: allow the bundled African-capitals fallback when places.placesGeo
# has no capital data. Never set "true" in production.
# FUNDI_ALLOW_FALLBACK_CAPITALS="true"

# Note: generate_description uses the Workers AI binding (Kimi via the shamwari
# AI Gateway) — no API key needed.

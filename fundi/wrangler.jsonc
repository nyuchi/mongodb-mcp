{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "fundi",
  "main": "src/index.ts",
  "account_id": "125a2dfbc21f76a25c980609609e8218",
  "compatibility_date": "2025-04-01",
  // mongodb driver + the Agents SDK both require the Node.js compat layer.
  "compatibility_flags": ["nodejs_compat"],

  // FundiMcp (MCP surface) and FundiAgent (per-task executor) are Cloudflare
  // Agents — SQLite-backed Durable Objects.
  "durable_objects": {
    "bindings": [
      { "class_name": "FundiMcp", "name": "MCP_OBJECT" },
      { "class_name": "FundiAgent", "name": "FUNDI_AGENT" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["FundiMcp", "FundiAgent"]
    }
  ],

  // The task queue: this worker is both producer (submit) and consumer.
  "queues": {
    "producers": [{ "queue": "fundi-tasks", "binding": "TASK_QUEUE" }],
    "consumers": [
      {
        "queue": "fundi-tasks",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3,
        "dead_letter_queue": "fundi-tasks-dlq"
      }
    ]
  },

  // D1 task ledger. Create with `wrangler d1 create fundi-ledger` and paste the id.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "fundi-ledger",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],

  // Optional OSM-id dedupe / rate-limit cache.
  "kv_namespaces": [{ "binding": "DEDUP_KV", "id": "REPLACE_WITH_KV_NAMESPACE_ID" }],

  // Hourly sweeper for failed/partial stragglers.
  "triggers": { "crons": ["0 * * * *"] },

  "routes": [{ "pattern": "fundi.nyuchi.dev", "custom_domain": true }],

  "observability": { "enabled": true },

  "vars": {
    "FUNDI_ANTHROPIC_MODEL": "claude-haiku-4-5-20251001",
    "FUNDI_BOUNDARY_BBOX": "-36,-26,38,64"
  },

  "dev": { "port": 8789 }
}
